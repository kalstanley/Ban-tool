    "8": {"id": "terrorism",     "label": "Terrorism / Dangerous Content"},
    "9": {"id": "drugs",         "label": "Sale of Regulated Goods"},
    "10": {"id": "custom",       "label": "Custom Report (Manual Entry)"},
