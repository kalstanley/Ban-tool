# ─── Instagram API Endpoints ──────────────────────────────────────────────────────

INSTAGRAM_REPORT_REASONS = {
    "1": {"id": "impersonation", "label": "Impersonation Account"},
    "2": {"id": "spam",          "label": "Spam / Fake Engagement"},
    "3": {"id": "harassment",    "label": "Harassment / Bullying"},
    "4": {"id": "hate_speech",   "label": "Hate Speech / Violence Incitement"},
    "5": {"id": "nudity",        "label": "Nudity / Sexual Content"},
